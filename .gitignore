# h7-demo-kit — runtime artifacts (never commit)
# Generated by `make setup` / `make calibrate` / `make up`.
run/
!run/.gitkeep

# Cryptographic material — even demo keys MUST stay local
*.sec
*.key
*.pem
*.pkcs8
*.p12
*.pfx
keys/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs / ad-hoc
*.log
*.ndjson.bak

# Demo recordings (regenerated on each run)
docs/demo/*.gif

# Private GTM materials (never publish)
docs/sales/
