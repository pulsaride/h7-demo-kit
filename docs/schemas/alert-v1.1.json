{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulsaride.dev/schemas/h7/alert-v1.1.json",
  "title": "H7_ALERT v1.1",
  "description": "Stream event emitted by h7-sensor at every ok\u2192alert transition (see F-002, ADR-PROD-012). One line per event in run/logs/alerts.ndjson; each event also has a signed Ed25519 sidecar at alert_cert_path.",
  "type": "object",
  "required": [
    "event",
    "version",
    "ts_ns",
    "ts_iso",
    "host",
    "metric",
    "tick",
    "kappa",
    "cusum_s",
    "h",
    "k_slack",
    "k_short",
    "k_long",
    "mu_baseline",
    "switches",
    "n_pids",
    "severity",
    "shadow_mode",
    "alert_cert_path"
  ],
  "additionalProperties": false,
  "properties": {
    "event":            { "const": "H7_ALERT" },
    "version":          { "const": "1.1" },
    "ts_ns":            { "type": "integer", "minimum": 0, "description": "Monotonic ns since sensor start." },
    "ts_iso":           { "type": "string",  "format": "date-time" },
    "host":             { "type": "string",  "minLength": 1 },
    "metric":           { "enum": ["sched_switch"] },
    "tick":             { "type": "integer", "minimum": 0 },
    "kappa":            { "type": "number" },
    "cusum_s":          { "type": "number" },
    "h":                { "type": "number", "exclusiveMinimum": 0, "description": "CUSUM decision threshold." },
    "k_slack":          { "type": "number", "minimum": 0 },
    "k_short":          { "type": "integer", "minimum": 1 },
    "k_long":           { "type": "integer", "minimum": 1 },
    "mu_baseline":      { "type": "number" },
    "switches":         { "type": "integer", "minimum": 0 },
    "n_pids":           { "type": "integer", "minimum": 0 },
    "severity":         { "enum": ["INFO", "WARN", "CRITICAL"] },
    "shadow_mode":      { "type": "boolean" },
    "alert_cert_path":  { "type": "string", "pattern": "alert-\\d+\\.cal$" }
  }
}
